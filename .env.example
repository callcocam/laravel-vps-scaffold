APP_NAME=myapp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://myapp.localhost

# Docker host port mappings (altere se houver conflito com outros projetos)
POSTGRES_FORWARD_PORT=5434
PGADMIN_FORWARD_PORT=5052
REDIS_FORWARD_PORT=6381
MAILPIT_SMTP_FORWARD_PORT=1027
MAILPIT_UI_FORWARD_PORT=8027

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Banco — conexão única (Postgres por padrão; troque para mysql se preferir)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=myapp
DB_USERNAME=myapp
DB_PASSWORD=myapp

# Redis — cache, fila e sessão
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=default
REDIS_CACHE_CONNECTION=cache
BROADCAST_CONNECTION=log

# Mail — Mailpit captura tudo localmente (UI em http://localhost:8027)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@myapp.localhost"
MAIL_FROM_NAME="${APP_NAME}"
