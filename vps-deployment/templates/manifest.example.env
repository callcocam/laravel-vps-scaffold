PROJECT_NAME=myapp

# Domínio raiz da aplicação.
DOMAIN=app.example.com
TRAEFIK_DASHBOARD_HOST=traefik.example.com
ACME_EMAIL=ops@example.com

# Deployment user
DEPLOY_USER=deploy
VPS_DEPLOY_USER=deploy
VPS_HOST=203.0.113.10
SSH_PORT=22

# Registry
GHCR_REPO=callcocam/myapp

# GitHub bootstrap
GITHUB_OWNER=callcocam
GITHUB_REPO_NAME=myapp

# Inject GitHub Actions public key used for deployment
GITHUB_DEPLOY_PUBLIC_KEY='ssh-ed25519 AAAA...replace-me'

# Traefik dashboard auth generated with:
# htpasswd -nb admin 'strong-password' | sed -e s/\$/\$\$/g
TRAEFIK_DASHBOARD_BASICAUTH=admin:$$apr1$$replace$$$$replace

# Application DB (conexão única)
# DB_MODE: local (banco na mesma VPS) | externo (VPS separada para o banco)
DB_MODE=local
DB_ENGINE=pgsql
# DB_CONNECTION_DEFAULT casa com DB_ENGINE (pgsql|mysql). Deixe vazio para herdar do engine.
# DB_CONNECTION_DEFAULT=pgsql
# local (containers): host.docker.internal (recomendado) ou 172.17.0.1 (fallback)
# DB_LOCAL_HOST_FALLBACK permite ajustar o fallback local aceito na validação.
DB_LOCAL_HOST_FALLBACK=172.17.0.1
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=myapp_production
DB_USER=myapp_prod
DB_PASSWORD=replace-db-password

# DB host installation parameters
DB_ALLOWED_CIDR=10.10.0.0/24
DB_ALLOWED_HOST=%

# SSH key dedicada ao host do banco (gerada automaticamente pelo provision-external-db.sh)
# Preenchido automaticamente pelo wizard — não altere manualmente
# DB_SSH_KEY_PATH=~/.ssh/id_ed25519_myapp_db

# Senha root da VPS do banco para 1ª conexão (bootstrap inicial)
# Removida/esvaziada após o bootstrap — não deixar em produção
# DB_BOOTSTRAP_ROOT_PASS=

# Optional predefined redis password
# REDIS_PASSWORD=replace

# Backup target: DigitalOcean Spaces (S3 compatible)
BACKUP_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
BACKUP_S3_REGION=us-east-1
BACKUP_S3_BUCKET=myapp-backups
BACKUP_S3_PREFIX=myapp
BACKUP_S3_ACCESS_KEY_ID=replace-do-spaces-key
BACKUP_S3_SECRET_ACCESS_KEY=replace-do-spaces-secret

# Tabelas para backup seletivo (comma-separated). Vazio = banco inteiro (recomendado).
# Ex (MySQL): BACKUP_TABLES=users,orders   | (PostgreSQL): BACKUP_TABLES=public.users,public.orders
# O wizard de setup pergunta por este valor automaticamente.
BACKUP_TABLES=

# Backup cron schedule (default: 02:10 daily)
BACKUP_CRON_MINUTE=10
BACKUP_CRON_HOUR=2
BACKUP_CRON_DAY_OF_MONTH=*
BACKUP_CRON_MONTH=*
BACKUP_CRON_DAY_OF_WEEK=*
BACKUP_LOG_DIR=/var/log/myapp

# --- Backup por tenant (OPCIONAL, só para multitenancy banco-por-tenant) ---------------
# Exceção aos princípios #1/#2 do blueprint (conexão única). Deixe false a menos que o
# projeto tenha adotado spatie/laravel-multitenancy com UM BANCO POSTGRES POR TENANT —
# aí o backup padrão (um DB_NAME só) cobriria apenas o landlord, e os dados dos clientes
# nunca seriam salvos. Ver vps-deployment/README.md → "Backup por tenant".
# Instala db/postgres-backup-{hot,full}.sh no lugar de automation/backup-db.sh.
BACKUP_MULTITENANT=false

# Donos (roles) dos bancos. Os bancos são DESCOBERTOS por dono, não listados: landlord +
# cada tenant novo entram sozinhos. Vazio = usa DB_USER.
# BACKUP_DB_OWNERS=myapp_prod,myapp_staging

# Tabelas "quentes" do tier rápido (a cada 30min). Conhecimento do domínio do app — não há
# default genérico. Vazio = tier rápido desativado, só o backup diário completo roda.
# BACKUP_HOT_TABLES=

# Tabelas fora do tier completo. Default = efêmeras do Laravel (sem valor de restore).
# BACKUP_EXCLUDED_TABLES=cache,cache_locks,sessions,jobs,job_batches,failed_jobs,migrations,password_reset_tokens

# BACKUP_HOT_CRON_SCHEDULE=*/30 * * * *
# BACKUP_FULL_CRON_SCHEDULE=20 3 * * *
# BACKUP_HOT_RETENTION_COUNT=48    # rodadas mantidas (local e no bucket) — 48 x 30min = 24h
# BACKUP_FULL_RETENTION_COUNT=14   # 14 dias
# BACKUP_OS_USER=postgres          # usuário OS que roda o dump (peer auth)
# BACKUP_ROOT_DIR=/opt/backups

# Optional pgAdmin
ENABLE_PGADMIN=false
PGADMIN_DOMAIN=pgadmin.example.com
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace-pgadmin-password

# Dedicated backup failure notification webhook
BACKUP_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/replace-backup-fail

# Validation
MIN_DISK_GB=20

# VPS health cron (default: every 15 minutes)
HEALTH_CRON_MINUTE=*/15
HEALTH_CRON_HOUR=*
HEALTH_CRON_DAY_OF_MONTH=*
HEALTH_CRON_MONTH=*
HEALTH_CRON_DAY_OF_WEEK=*
HEALTH_LOG_DIR=/var/log/myapp
