# Credenciais S3-compatible (testado com DigitalOcean Spaces) dos tiers de backup
# banco-a-banco. Instalado em /etc/<PROJECT_NAME>/spaces-backup-credentials.env pelo
# install-tenant-backup-cron.sh, a partir do bloco BACKUP_S3_* do manifest.
# NUNCA versionar o arquivo preenchido.
#
# Os scripts rodam como usuário OS `postgres` — não como root — então diretório e arquivo
# precisam ser legíveis por ele. /root é 700 e bloqueia outros usuários até no `cd`, por
# isso o arquivo não fica lá:
#   mkdir -p /etc/<PROJECT_NAME>
#   chown postgres:postgres /etc/<PROJECT_NAME>
#   chmod 750 /etc/<PROJECT_NAME>
#   chown postgres:postgres /etc/<PROJECT_NAME>/spaces-backup-credentials.env
#   chmod 600 /etc/<PROJECT_NAME>/spaces-backup-credentials.env

BACKUP_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
BACKUP_S3_REGION=us-east-1
BACKUP_S3_BUCKET=myapp-backups
BACKUP_S3_ACCESS_KEY_ID=replace-with-real-key
BACKUP_S3_SECRET_ACCESS_KEY=replace-with-real-secret
