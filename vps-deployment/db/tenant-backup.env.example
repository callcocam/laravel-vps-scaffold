# Config dos tiers de backup banco-a-banco (multitenancy banco-por-tenant).
# Instalado em /etc/<PROJECT_NAME>/tenant-backup.env pelo install-tenant-backup-cron.sh,
# que gera este arquivo a partir do manifest. Editar aqui só para ajuste pontual na VPS.
#
# Precisa ser legível pelo usuário OS que roda o backup (BACKUP_OS_USER, tipicamente
# `postgres`) — por isso NÃO fica em /root (modo 700 bloqueia outros usuários):
#   mkdir -p /etc/<PROJECT_NAME> && chown postgres:postgres /etc/<PROJECT_NAME> && chmod 750 /etc/<PROJECT_NAME>

# SEMPRE aspeie as listas: este arquivo é `source`ado, e `A=a, b` (com espaço, sem aspas)
# vira um prefixo de env + comando `b` — a variável fica VAZIA e o tier morre em silêncio.

# Donos (roles Postgres) dos bancos a incluir. Os bancos são DESCOBERTOS por dono,
# não listados — landlord + cada tenant entram sozinhos, e bancos de outros donos
# (testes avulsos, `postgres`, templates) ficam de fora sem lista de exclusão.
BACKUP_DB_OWNERS='myapp_prod,myapp_staging'

# Tier RÁPIDO — tabelas "quentes" do domínio (mudam o tempo todo). Não existe default
# genérico: isto é conhecimento do app. Vazio = tier rápido desativado, só o completo roda.
BACKUP_HOT_TABLES=''

# Tier COMPLETO — tudo, menos estas. Default do scaffold = efêmeras do Laravel.
BACKUP_EXCLUDED_TABLES='cache,cache_locks,sessions,jobs,job_batches,failed_jobs,migrations,password_reset_tokens'

# Rodadas mantidas (local E no bucket).
BACKUP_HOT_RETENTION_COUNT=48   # 48 x 30min = 24h
BACKUP_FULL_RETENTION_COUNT=14  # 14 dias

BACKUP_ROOT_DIR=/opt/backups
BACKUP_LOG_DIR=/var/log/myapp
BACKUP_S3_PREFIX=db-backups

# Credenciais S3 num arquivo à parte (modo 600) — ver spaces-credentials.env.example.
BACKUP_S3_CREDENTIALS_FILE=/etc/myapp/spaces-backup-credentials.env
